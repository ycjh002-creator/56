-- ==================== 換服函數 ====================
local ServerBtnX = 98.8
local ServerBtnY = 2
local JoinX = 69.3
local JoinY = 41.4
local ListX = 48.0
local ListY = 50.7
local KeepAliveX = 49.7
local KeepAliveY = 53.1

local function clickAt(percentX, percentY)
    local sx = workspace.CurrentCamera.ViewportSize.X
    local sy = workspace.CurrentCamera.ViewportSize.Y
    local x = sx * (percentX / 100)
    local y = sy * (percentY / 100)
    VIM:SendMouseMoveEvent(x, y, game)
    task.wait(0.1)
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.08)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

local function getServerScroll()
    local sb = player.PlayerGui:FindFirstChild("ServerBrowser")
    if sb then
        return sb:FindFirstChild("ScrollingFrame", true)
    end
    return nil
end

local function jumpRandom()
    local scroll = getServerScroll()
    if not scroll then return false end
    local maxY = scroll.CanvasSize.Y.Offset
    if maxY <= 0 then return false end
    local randomY = math.random(0, math.floor(maxY))
    scroll.CanvasPosition = Vector2.new(0, randomY)
    return true
end

local function serverHop()
    if isVoidEnabled then
        isVoidEnabled = false
        stopSlot1Spam()
        if voidThread then task.cancel(voidThread); voidThread = nil end
        returnToPosition()
    end
    waitingForReset = false

    local currentJob = game.JobId

    clickAt(ServerBtnX, ServerBtnY)
    task.wait(3)

    local keepAliveThread = task.spawn(function()
        while game.JobId == currentJob do
            task.wait(5)
            if game.JobId == currentJob then
                clickAt(KeepAliveX, KeepAliveY)
            end
        end
    end)

    while game.JobId == currentJob do
        jumpRandom()
        task.wait(0.5)
        local randomY = math.random(15, 85)
        clickAt(ListX, randomY)
        task.wait(0.3)
        clickAt(JoinX, JoinY)
        task.wait(5)
    end

    if keepAliveThread then task.cancel(keepAliveThread) end
end

-- ==================== 戰鬥狀態偵測 ====================
local function IsPlayerInCombat()
    local character = player.Character
    local playerGui = player:FindFirstChild("PlayerGui")
    if character and (character:GetAttribute("SafeZone") or character:GetAttribute("IsInSafeZone")) then return false end
    if playerGui and playerGui:FindFirstChild("Main") then
        local safeZoneUI = playerGui.Main:FindFirstChild("SafeZone")
        if safeZoneUI and safeZoneUI.Visible then return false end
    end
    local combatTag = character and (character:FindFirstChild("Combat") or character:FindFirstChild("combat"))
    if combatTag and combatTag:IsA("BoolValue") and combatTag.Value == true then return true end
    if playerGui then
        local main = playerGui:FindFirstChild("Main")
        if main then
            for _, obj in ipairs(main:GetDescendants()) do
                if obj:IsA("TextLabel") and obj.Visible and obj.TextTransparency < 0.1 then
                    local text = obj.Text
                    if text:find("In Combat") or text:find("at risk") then
                        local color = obj.TextColor3
                        if color.R > 0.7 and color.G < 0.4 and color.B < 0.4 then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

