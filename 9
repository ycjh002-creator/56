local function PerformVoidCombo()
    if VoidComboState.IsRunning then return end
    VoidComboState.IsRunning = true
    
    local char = LocalPlayer.Character
    if not char then
        VoidComboState.IsRunning = false
        return
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        VoidComboState.IsRunning = false
        return
    end
    
    local posX = root.Position.X
    local posY = root.Position.Y
    local posZ = root.Position.Z
    local originalCFrame = root.CFrame
    
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, nil)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, nil)
    
    task.wait(0.14)
    root.CFrame = CFrame.new(posX, 7e29, posZ)
    task.wait(0.15)
    
    root.CFrame = originalCFrame
    
    task.delay(0.5, function()
        if root and root.Parent then
            local currentY = root.Position.Y
            if currentY > 100000 then
                root.CFrame = CFrame.new(posX, posY, posZ)
            end
        end
    end)
    
    VoidComboState.IsRunning = false
end

