_G.ActivityFunctions.ROTATION_CONFIG = {
    Enabled = false,
    RotationSpeed = 2000,
}

_G.ActivityFunctions.rotationActive = false
_G.ActivityFunctions.rotationConnection = nil
_G.ActivityFunctions.moveKeys = {W=false, A=false, S=false, D=false}
_G.ActivityFunctions.jumpHoldRot = false
_G.ActivityFunctions.currentYaw = 0
_G.ActivityFunctions.rotationInputBegan = nil
_G.ActivityFunctions.rotationInputEnded = nil

local function setupRotationInput()
    if _G.ActivityFunctions.rotationInputBegan then
        _G.ActivityFunctions.rotationInputBegan:Disconnect()
        _G.ActivityFunctions.rotationInputBegan = nil
    end
    if _G.ActivityFunctions.rotationInputEnded then
        _G.ActivityFunctions.rotationInputEnded:Disconnect()
        _G.ActivityFunctions.rotationInputEnded = nil
    end
    
    _G.ActivityFunctions.rotationInputBegan = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not _G.ActivityFunctions.ROTATION_CONFIG.Enabled then return end
        
        if input.KeyCode == Enum.KeyCode.W then _G.ActivityFunctions.moveKeys.W = true end
        if input.KeyCode == Enum.KeyCode.A then _G.ActivityFunctions.moveKeys.A = true end
        if input.KeyCode == Enum.KeyCode.S then _G.ActivityFunctions.moveKeys.S = true end
        if input.KeyCode == Enum.KeyCode.D then _G.ActivityFunctions.moveKeys.D = true end
        if input.KeyCode == Enum.KeyCode.Space then _G.ActivityFunctions.jumpHoldRot = true end
    end)

    _G.ActivityFunctions.rotationInputEnded = UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if input.KeyCode == Enum.KeyCode.W then _G.ActivityFunctions.moveKeys.W = false end
        if input.KeyCode == Enum.KeyCode.A then _G.ActivityFunctions.moveKeys.A = false end
        if input.KeyCode == Enum.KeyCode.S then _G.ActivityFunctions.moveKeys.S = false end
        if input.KeyCode == Enum.KeyCode.D then _G.ActivityFunctions.moveKeys.D = false end
        if input.KeyCode == Enum.KeyCode.Space then _G.ActivityFunctions.jumpHoldRot = false end
    end)
end

local function startRotation()
    if _G.ActivityFunctions.rotationActive then return end
    
    local character = LocalPlayer.Character
    if not character then 
        if WindUI then WindUI:Notify({ Title = "免控旋轉", Content = "找不到角色", Duration = 2 }) end
        return 
    end
    
    local root = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not root or not humanoid then 
        if WindUI then WindUI:Notify({ Title = "免控旋轉", Content = "角色組件不完整", Duration = 2 }) end
        return 
    end
    
    humanoid.AutoRotate = false
    _G.ActivityFunctions.rotationActive = true
    _G.ActivityFunctions.currentYaw = root.Orientation.Y
    setupRotationInput()
    
    _G.ActivityFunctions.rotationConnection = RunService.Heartbeat:Connect(function(dt)
        if not _G.ActivityFunctions.ROTATION_CONFIG.Enabled or not _G.ActivityFunctions.rotationActive then return end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if not rootPart or not hum then return end
        if hum.Health <= 0 then return end
        
        _G.ActivityFunctions.currentYaw = _G.ActivityFunctions.currentYaw + _G.ActivityFunctions.ROTATION_CONFIG.RotationSpeed * dt
        
        local camCFrame = workspace.CurrentCamera.CFrame
        local camLook = Vector3.new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z)
        local camRight = Vector3.new(camCFrame.RightVector.X, 0, camCFrame.RightVector.Z)
        
        local direction = Vector3.new(0, 0, 0)
        if _G.ActivityFunctions.moveKeys.W then direction = direction + camLook end
        if _G.ActivityFunctions.moveKeys.S then direction = direction - camLook end
        if _G.ActivityFunctions.moveKeys.A then direction = direction - camRight end
        if _G.ActivityFunctions.moveKeys.D then direction = direction + camRight end
        
        if direction.Magnitude > 0 then
            hum:Move(direction.Unit, false)
        else
            hum:Move(Vector3.new(0,0,0), false)
        end
        
        if _G.ActivityFunctions.jumpHoldRot and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
            hum.Jump = true
        else
            hum.Jump = false
        end
        
        rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, math.rad(_G.ActivityFunctions.currentYaw), 0)
    end)
    
    if WindUI then
        WindUI:Notify({ 
            Title = "免控旋轉", 
            Content = "免控功能已開啟", 
            Duration = 3 
        })
    end
end

local function stopRotation()
    _G.ActivityFunctions.rotationActive = false
    _G.ActivityFunctions.ROTATION_CONFIG.Enabled = false
    
    if _G.ActivityFunctions.rotationConnection then
        _G.ActivityFunctions.rotationConnection:Disconnect()
        _G.ActivityFunctions.rotationConnection = nil
    end
    
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.AutoRotate = true
            humanoid.Jump = false
        end
    end
    
    _G.ActivityFunctions.moveKeys = {W=false, A=false, S=false, D=false}
    _G.ActivityFunctions.jumpHoldRot = false
    
    if WindUI then
        WindUI:Notify({ Title = "免控旋轉", Content = "免控功能已關閉", Duration = 2 })
    end
end

