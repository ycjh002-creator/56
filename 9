            setupKeyboardJumpDetection()
            WindUI:Notify({ 
                Title = "跳躍修改", 
                Content = "PC模式已開啟，按住空白鍵跳躍", 
                Duration = 2 
            })
        end
        
        startJumpLoop()
        updateJumpButtonHeight()
    else
        if jumpConnection then
            jumpConnection:Disconnect()
            jumpConnection = nil
        end
        if jumpInputBegan then
            jumpInputBegan:Disconnect()
            jumpInputBegan = nil
        end
        if jumpInputEnded then
            jumpInputEnded:Disconnect()
            jumpInputEnded = nil
        end
        
        jumpHold = false
        
        if mobileJumpGui then
            mobileJumpGui.Enabled = false
        end
        
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.Jump = false
            end
        end
        
        WindUI:Notify({ 
            Title = "跳躍修改", 
            Content = "已關閉", 
            Duration = 2 
        })
    end
end

