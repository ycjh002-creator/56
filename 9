-- 滑桿功能
local function updateSlider(input)
    if not bgEnabled then
        local percent = alphaValue
        SliderFill.Size = UDim2.new(percent, 0, 1, 0)
        SliderKnob.Position = UDim2.new(percent, -10, 0.5, -10)
        AlphaValueLabel.Text = string.format("%.2f", alphaValue)
        return
    end
    
    local sliderPos = input.Position.X - SliderBg.AbsolutePosition.X
    local percent = math.clamp(sliderPos / SliderBg.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(percent, 0, 1, 0)
    SliderKnob.Position = UDim2.new(percent, -10, 0.5, -10)
    alphaValue = percent
    AlphaValueLabel.Text = string.format("%.2f", alphaValue)
end

local function jumpSlider(input)
    if not bgEnabled then return end
    
    local sliderPos = input.Position.X - SliderBg.AbsolutePosition.X
    local percent = math.clamp(sliderPos / SliderBg.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(percent, 0, 1, 0)
    SliderKnob.Position = UDim2.new(percent, -10, 0.5, -10)
    alphaValue = percent
    AlphaValueLabel.Text = string.format("%.2f", alphaValue)
end

SliderBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
