local function updateJumpButtonHeight()
    if mobileJumpButton and mobileJumpButton.Parent then
        for _, child in ipairs(mobileJumpButton:GetChildren()) do
            if child:IsA("TextLabel") and child.Size.Y.Scale < 1 then
                child.Text = string.format("↑ %d", JUMP_HEIGHT)
