end

local function setJumpEnabled(enabled)
    jumpEnabled = enabled
    
    if enabled then
        isMobile = detectMobile()
        
        if isMobile then
            if not mobileJumpGui or not mobileJumpGui.Parent then
                createMobileJumpButton()
            else
                mobileJumpGui.Enabled = true
            end
            WindUI:Notify({ 
                Title = "跳躍修改", 
                Content = "手機模式已開啟，點擊畫面右下角的跳躍按鈕", 
                Duration = 3 
