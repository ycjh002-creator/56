-- ================= 手機兼容的跳躍高度修改器 (純觸控點擊版) =================
local JUMP_HEIGHT = 100
local jumpEnabled = false
local jumpHold = false
local jumpConnection = nil
local jumpInputBegan = nil
local jumpInputEnded = nil
local mobileJumpButton = nil
local mobileJumpGui = nil
local isMobile = false

-- 檢測是否為手機設備
local function detectMobile()
    local guiService = game:GetService("GuiService")
    local touchEnabled = UserInputService.TouchEnabled
    local keyboardEnabled = UserInputService.KeyboardEnabled
    local mouseEnabled = UserInputService.MouseEnabled
    
    if touchEnabled and not keyboardEnabled and not mouseEnabled then
        return true
    elseif guiService:IsTenFootInterface() then
        return false
    else
        return false
    end
end

isMobile = detectMobile()

local function setupKeyboardJumpDetection()
    if jumpInputBegan then
        jumpInputBegan:Disconnect()
        jumpInputBegan = nil
    end
    if jumpInputEnded then
        jumpInputEnded:Disconnect()
        jumpInputEnded = nil
    end
    
    jumpInputBegan = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or not jumpEnabled then return end
        if input.KeyCode == Enum.KeyCode.Space then
            jumpHold = true
        end
        if input.KeyCode == Enum.KeyCode.ButtonA then
            jumpHold = true
        end
    end)
    
    jumpInputEnded = UserInputService.InputEnded:Connect(function(input, gpe)
        if input.KeyCode == Enum.KeyCode.Space then
            jumpHold = false
        end
        if input.KeyCode == Enum.KeyCode.ButtonA then
            jumpHold = false
        end
    end)
end

local function startJumpLoop()
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
    
    jumpConnection = RunService.Heartbeat:Connect(function(dt)
        if jumpEnabled and jumpHold then
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if root and humanoid and humanoid.Health > 0 then
                    if root.Velocity.Y < JUMP_HEIGHT then
                        local force = JUMP_HEIGHT * 2
                        root.Velocity = Vector3.new(root.Velocity.X, math.min(root.Velocity.Y + force * dt, JUMP_HEIGHT), root.Velocity.Z)
                    end
                    if humanoid:GetState() ~= Enum.HumanoidStateType.Jumping and 
                       humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then
                        humanoid.Jump = true
                    end
                end
            end
        else
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.Jump = false
                end
            end
        end
    end)
end

