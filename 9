local function PerformTeleportAndZx()
    local teleportTarget = nil
    
    if AimbotConfig.Mode == "Specific" then
        teleportTarget = selectedTargetPlayer
        if not teleportTarget then
            WindUI:Notify({ Title = "傳送+ZX", Content = "請先選擇目標玩家", Duration = 2, Icon = "alert-triangle" })
