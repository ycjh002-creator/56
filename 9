local function SetupVoidCharacter(char)
    voidCharacter = char
    voidRoot = char:WaitForChild("HumanoidRootPart")
end

if LocalPlayer.Character then SetupVoidCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(SetupVoidCharacter)

local function TPVoid(preSavedCFrame)
    if VoidState.IsTeleporting or not InstantKillConfig.Enabled then return end
    if not voidRoot or not voidCharacter then return end
    local humanoid = voidCharacter:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end
    
    VoidState.IsTeleporting = true
    
    if InstantKillConfig.ShowNotifications then
        WindUI:Notify({ Title = "秒殺觸發", Content = "閃避攻擊並傳送至虛空", Duration = 1, Icon = "zap" })
    end
    
    local heartbeatConn
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if voidRoot then
            local pos = voidRoot.Position
            voidRoot.CFrame = CFrame.new(pos.X, InstantKillConfig.TeleportY, pos.Z)
            voidRoot.AssemblyLinearVelocity = Vector3.zero
        end
    end)
    
    task.wait(InstantKillConfig.VoidTime)
    if heartbeatConn then heartbeatConn:Disconnect() end
    
    if voidRoot and humanoid.Health > 0 then
        voidRoot.CFrame = preSavedCFrame + Vector3.new(0, 0.5, 0)
        voidRoot.AssemblyLinearVelocity = Vector3.zero
        voidRoot.AssemblyAngularVelocity = Vector3.zero
    end
    
    task.wait(0.1)
    VoidState.IsTeleporting = false
end

local function StartInstantKill()
    if killConnection then killConnection:Disconnect() end
    trackedSounds = {}
    
    local soundsFolder = workspace:FindFirstChild("_WorldOrigin") or Instance.new("Folder")
    if not soundsFolder.Parent then
        soundsFolder.Name = "_WorldOrigin"
        soundsFolder.Parent = workspace
    end
    local sounds = soundsFolder:FindFirstChild("Sounds") or Instance.new("Folder")
    if not sounds.Parent then
        sounds.Name = "Sounds"
        sounds.Parent = soundsFolder
    end
    
    killConnection = RunService.RenderStepped:Connect(function()
        if not InstantKillConfig.Enabled or not voidRoot then return end
        for _, obj in ipairs(sounds:GetDescendants()) do
            if obj:IsA("Sound") and not trackedSounds[obj] then
                local shouldTrigger = false
                local soundName = obj.Name
                
                if soundName == "SaddiHit" or soundName == "SaishiHit" then
                    shouldTrigger = InstantKillConfig.EnableSaddiHit
                elseif soundName == "DoughDrip" then
                    shouldTrigger = InstantKillConfig.EnableDoughDrip
                elseif soundName == "Buddha2pickup" or soundName == "BuddhaHit" then
                    shouldTrigger = InstantKillConfig.EnableBuddhaHit
                end
                
                if shouldTrigger then
                    trackedSounds[obj] = true
                    TPVoid(voidRoot.CFrame)
                end
            end
        end
        for soundObj in pairs(trackedSounds) do
            if not soundObj:IsDescendantOf(sounds) then trackedSounds[soundObj] = nil end
        end
    end)
    
    WindUI:Notify({ Title = "秒殺功能", Content = "已開啟 - 自動閃避攻擊", Duration = 3, Icon = "zap" })
end

local function StopInstantKill()
    if killConnection then killConnection:Disconnect() end
    trackedSounds = {}
    VoidState.IsTeleporting = false
    WindUI:Notify({ Title = "秒殺功能", Content = "已關閉", Duration = 2 })
end

