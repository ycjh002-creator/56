-- ==================== 龍泉z秒殺全自動 ====================
local function voidLock_DragonSpring(character)
    while DragonSpringZKillConfig.Enabled and character and character.Parent do
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = DragonSpringZKillConfig.VOID_POSITION
        end
        task.wait()
    end
end

local function mainLoop_DragonSpring()
    while DragonSpringZKillConfig.Enabled do
        DragonSpringZKillConfig.StatusText = "等待角色..."
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")

        if not root or not humanoid then
            task.wait(0.5)
            continue
        end

        -- 重生後等0.2秒
        DragonSpringZKillConfig.StatusText = "等待 " .. DragonSpringZKillConfig.SPAWN_DELAY .. " 秒..."
        task.wait(DragonSpringZKillConfig.SPAWN_DELAY)

        -- 瞬間傳送虛空 + 啟動虛空鎖定
        root.CFrame = DragonSpringZKillConfig.VOID_POSITION
        DragonSpringZKillConfig.VoidThread = task.spawn(function()
            voidLock_DragonSpring(char)
        end)

        -- 瞬間切欄1
        local keyMap = { [1] = Enum.KeyCode.One, [2] = Enum.KeyCode.Two, [3] = Enum.KeyCode.Three }
        local function switchToSlot_DragonSpring(slot)
            if keyMap[slot] then
                VirtualInputManager:SendKeyEvent(true, keyMap[slot], false, nil)
                task.wait(0.01)
                VirtualInputManager:SendKeyEvent(false, keyMap[slot], false, nil)
            end
        end
        switchToSlot_DragonSpring(1)

        -- 按3次Z後重生
        local hitCount = 0
        while DragonSpringZKillConfig.Enabled and humanoid.Health > 0 and LocalPlayer.Character == char do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, nil)
            task.wait(0.01)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Z, false, nil)
            hitCount = hitCount + 1
            DragonSpringZKillConfig.StatusText = "按Z中... (" .. hitCount .. "/" .. DragonSpringZKillConfig.RESET_THRESHOLD .. ")"

            if hitCount >= DragonSpringZKillConfig.RESET_THRESHOLD then
                DragonSpringZKillConfig.StatusText = "重生中..."
                if humanoid.Health > 0 then
                    humanoid.Health = 0
                end
                break
            end

            task.wait(0.01)
        end

        -- 停止虛空鎖定
        if DragonSpringZKillConfig.VoidThread then
            task.cancel(DragonSpringZKillConfig.VoidThread)
            DragonSpringZKillConfig.VoidThread = nil
        end

        task.wait(0.1)
    end
    DragonSpringZKillConfig.StatusText = "已關閉"
end

local function ToggleDragonSpringZKill()
    if DragonSpringZKillConfig.Enabled then
        -- 關閉功能
        DragonSpringZKillConfig.Enabled = false
        if DragonSpringZKillConfig.MainThread then
            task.cancel(DragonSpringZKillConfig.MainThread)
            DragonSpringZKillConfig.MainThread = nil
        end
        if DragonSpringZKillConfig.VoidThread then
            task.cancel(DragonSpringZKillConfig.VoidThread)
            DragonSpringZKillConfig.VoidThread = nil
        end
        DragonSpringZKillConfig.StatusText = "已關閉"

        if dragonSpringZKillButton then
            dragonSpringZKillButton:SetTitle("龍泉z秒殺全自動 [關閉]")
        end
        if dragonSpringStatusLabel then
            dragonSpringStatusLabel:SetDesc("已關閉")
        end

        WindUI:Notify({ Title = "龍泉z秒殺全自動", Content = "已關閉", Duration = 2 })
    else
        -- 開啟功能
        DragonSpringZKillConfig.Enabled = true
        DragonSpringZKillConfig.StatusText = "啟動中..."
        DragonSpringZKillConfig.MainThread = task.spawn(mainLoop_DragonSpring)

        if dragonSpringZKillButton then
            dragonSpringZKillButton:SetTitle("龍泉z秒殺全自動 [運作中]")
        end

        WindUI:Notify({
            Title = "龍泉z秒殺全自動",
            Content = "已開啟 - 重生 → 等" .. DragonSpringZKillConfig.SPAWN_DELAY .. "秒 → 虛空 → 切欄1 → 按" .. DragonSpringZKillConfig.RESET_THRESHOLD .. "次Z → 重生 → 循環",
            Duration = 5
        })
    end
end

