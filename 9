        local function performHealthTeleport()
            local character = LocalPlayer.Character
            if not character or not character:FindFirstChild("HumanoidRootPart") then
                return false
            end
            
            local hrp = character.HumanoidRootPart
            local location = HealthDetectConfig.SelectedLocation
            local locationData = TeleportLocations[location]
            
            if not locationData then
                return false
            end
            
            local success = false
            
            if locationData.type == "remote" then
                pcall(function()
                    ReplicatedStorage.Remotes.CommF_:InvokeServer(locationData.remote)
                    success = true
                end)
            elseif locationData.type == "cframe" then
                hrp.CFrame = locationData.CFrame
                success = true
            elseif locationData.type == "custom" then
                hrp.CFrame = CFrame.new(CustomX, CustomY, CustomZ)
                success = true
            end
            
            if success then
                HealthDetectConfig.LastTeleportTime = tick()
                
                if HealthDetectConfig.ShowNotifications then
                    WindUI:Notify({
                        Title = "⚠️ 血量危急 ⚠️",
                        Content = string.format("血量低於 %d%%，自動傳送至 %s", 
                            HealthDetectConfig.HealthThreshold, 
                            location),
                        Duration = 5,
                        Icon = "heart"
                    })
                end
                
                return true
            end
            
            return false
        end
        
