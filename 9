                    CreatePlayerInfoESP(player)
                else
                    if ESPElements[player.UserId] and ESPElements[player.UserId].PlayerInfoESP then
                        ESPElements[player.UserId].PlayerInfoESP:Destroy()
                        ESPElements[player.UserId].PlayerInfoESP = nil
                    end
