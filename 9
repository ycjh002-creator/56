        end
    end
    
    if not teleportTarget.Character or not teleportTarget.Character:FindFirstChild("HumanoidRootPart") then
        WindUI:Notify({ Title = "傳送+ZX", Content = "目標玩家無效", Duration = 2 })
        return false
    end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        WindUI:Notify({ Title = "傳送+ZX", Content = "找不到你的角色", Duration = 2 })
        return false
    end
    
    local hrp = character.HumanoidRootPart
    local targetRoot = teleportTarget.Character.HumanoidRootPart
    if not hrp or not targetRoot then return false end
    
    local direction = (targetRoot.Position - hrp.Position).Unit
    local teleportPos = targetRoot.Position - direction * TeleportZxConfig.TeleportDistance
    
    local savedCollision = {}
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            savedCollision[part] = part.CanCollide
            part.CanCollide = false
        end
    end
    
    hrp.CFrame = CFrame.new(teleportPos, targetRoot.Position)
    hrp.Velocity = Vector3.zero
    hrp.AssemblyLinearVelocity = Vector3.zero
    
    local modeText = AimbotConfig.Mode == "Specific" and teleportTarget.Name or "最近玩家"
    WindUI:Notify({ Title = "傳送+ZX", Content = "已傳送到 " .. modeText .. " 附近", Duration = 1 })
    
    local virtualInput = game:GetService("VirtualInputManager")
    virtualInput:SendKeyEvent(true, Enum.KeyCode.Z, false, nil)
    task.wait(0.1)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.Z, false, nil)
    
    task.wait(TeleportZxConfig.SkillDelay)
    
    virtualInput:SendKeyEvent(true, Enum.KeyCode.X, false, nil)
    task.wait(0.1)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.X, false, nil)
    
    for part, canCollide in pairs(savedCollision) do
        if part and part.Parent then pcall(function() part.CanCollide = canCollide end) end
    end
    
    WindUI:Notify({ Title = "傳送+ZX", Content = "已施放 Z + X 技能", Duration = 1 })
    return true
end

