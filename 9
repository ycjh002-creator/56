            CycleConfig.Target = player
            CycleConfig.Enabled = true
            
            if cycleButton then
                cycleButton:SetTitle("停止循環傳送")
            end
            
            EnableNoClip()
            
            CycleConfig.CycleThread = task.spawn(function()
                while CycleConfig.Enabled do
                    local success, err = pcall(function()
                        local char = LocalPlayer.Character
                        local targetChar = player.Character
                        
                        if char and targetChar and char:FindFirstChild("HumanoidRootPart") and targetChar:FindFirstChild("HumanoidRootPart") then
                            local hrp = char.HumanoidRootPart
                            local targetHrp = targetChar.HumanoidRootPart
                            
                            local function SafeTeleport(cf)
                                hrp.Velocity = Vector3.new(0, 0, 0)
                                char:PivotTo(cf)
                            end
                            
                            local offsetCFrame = targetHrp.CFrame * CFrame.new(0, CycleConfig.OffsetY, 0)
                            SafeTeleport(offsetCFrame)
                            task.wait(CycleConfig.Interval)
                            
                            if not CycleConfig.Enabled then return end
                            
                            SafeTeleport(targetHrp.CFrame)
                            task.wait(CycleConfig.Interval)
                        else
                            StopCycleTeleport()
                        end
                    end)
                    
                    if not success then
                        task.wait(0.5)
                    end
                end
            end)
            
            WindUI:Notify({ 
                Title = "循環傳送", 
