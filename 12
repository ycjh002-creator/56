local function clickJoin()
    local offsetX = math.random(-12, 12)  -- 加大到 ±12%
    local offsetY = math.random(-8, 8)    -- 加大到 ±8%
    clickAt(JoinX + offsetX, JoinY + offsetY)
end

local function serverHop()
    if isVoidEnabled then
        isVoidEnabled = false
        stopSlot1Spam()
        if voidThread then task.cancel(voidThread); voidThread = nil end
        returnToPosition()
    end
    waitingForReset = false

    local currentJob = game.JobId
    local randomY = math.random(15, 85)
    local randomOffsetX = math.random(-3, 3)

    clickAt(ServerBtnX, ServerBtnY)
    task.wait(3)
    jumpRandom()
    task.wait(0.5)
    clickAt(ListX + randomOffsetX, randomY)
    task.wait(0.3)
    
    -- 點 Join，最多試5次
    for i = 1, 5 do
        clickJoin()
        task.wait(0.5)
        if game.JobId ~= currentJob then break end
    end
    
    -- 如果還沒換，再等3秒繼續試
    task.wait(3)
    if game.JobId == currentJob then
        for i = 1, 5 do
            clickJoin()
            task.wait(0.5)
            if game.JobId ~= currentJob then break end
        end
    end
    
    -- 最後再試
    task.wait(3)
    if game.JobId == currentJob then
        for i = 1, 5 do
            clickJoin()
            task.wait(0.5)
            if game.JobId ~= currentJob then break end
        end
    end
end
