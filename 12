-- ==================== 虛空傳送 + 戰鬥偵測 ====================
local isVoidEnabled = Settings.VoidEnabled
local savedPosition = nil
local voidThread = nil
local slot1SpamThread = nil
local trackedSounds = {}
local waitingForReset = false

local noCombatCount = 0
local maxNoCombat = 3
local combatCheckedThisCycle = false
local combatCheckEnabled = Settings.CombatHopEnabled

local function pressKey(keyCode)
    VIM:SendKeyEvent(true, keyCode, false, nil)
    task.wait(0.03)
    VIM:SendKeyEvent(false, keyCode, false, nil)
end

local function switchToSlot(slot)
    local keyMap = { [1] = Enum.KeyCode.One, [2] = Enum.KeyCode.Two, [3] = Enum.KeyCode.Three }
    if keyMap[slot] then pressKey(keyMap[slot]) end
end

local function stopSlot1Spam()
    if slot1SpamThread then task.cancel(slot1SpamThread); slot1SpamThread = nil end
end

local function startSlot1Spam()
    stopSlot1Spam()
    local trackedChar = player.Character
    if not trackedChar then return end
    
    combatCheckedThisCycle = false
    
    slot1SpamThread = task.spawn(function()
        while isVoidEnabled and player.Character == trackedChar do
            local humanoid = trackedChar:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health <= 0 then break end
            
            if combatCheckEnabled and not combatCheckedThisCycle then
                if IsPlayerInCombat() then
                    combatCheckedThisCycle = true
                    noCombatCount = 0
                end
            end
            
            pressKey(Enum.KeyCode.Z)
            task.wait(0.05)
        end
        
        if combatCheckEnabled and not combatCheckedThisCycle then
            noCombatCount = noCombatCount + 1
            if noCombatCount >= maxNoCombat then
                waitingForReset = true
            end
        end
        
        slot1SpamThread = nil
    end)
end

local function useSkills()
    if not isVoidEnabled or not player.Character then return end
    switchToSlot(3)
    task.wait(0.1)
    pressKey(Enum.KeyCode.Z)
    task.wait(0.1)
    switchToSlot(1)
    task.wait(0.1)
    startSlot1Spam()
end

local function voidLoop()
    while isVoidEnabled do
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then root.CFrame = CFrame.new(0, 7e29, 0) end
        end
        task.wait()
    end
end

local function savePosition()
    local char = player.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then savedPosition = root.CFrame end
    end
end

local function returnToPosition()
    if not savedPosition then return end
    local char = player.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = savedPosition end
    end
end

local function toggleVoid(state)
    Settings.VoidEnabled = state
    saveSettings()

    if state then
        stopSlot1Spam()
        savePosition()
        isVoidEnabled = true
        noCombatCount = 0
        voidThread = task.spawn(voidLoop)
        task.wait(0.3)
        useSkills()
    else
        isVoidEnabled = false
        stopSlot1Spam()
        if voidThread then task.cancel(voidThread); voidThread = nil end
        returnToPosition()
    end
end

if Settings.VoidEnabled then
    task.delay(5, function() toggleVoid(true) end)
end

local function resetCharacter()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.Health = 0
            if waitingForReset then
                isVoidEnabled = false
                stopSlot1Spam()
                if voidThread then task.cancel(voidThread); voidThread = nil end
                returnToPosition()
            end
        end
    end
end

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj.Name == "ZRelease" and obj:IsA("Sound") and obj.IsPlaying and not trackedSounds[obj] then
                    trackedSounds[obj] = true
                    resetCharacter()
                end
            end
            local char = player.Character
            if char then
                for _, obj in ipairs(char:GetDescendants()) do
                    if obj.Name == "ZRelease" and obj:IsA("Sound") and obj.IsPlaying and not trackedSounds[obj] then
                        trackedSounds[obj] = true
                        resetCharacter()
                    end
                end
            end
            for soundObj in pairs(trackedSounds) do
                if not soundObj.Parent or not soundObj.IsPlaying then trackedSounds[soundObj] = nil end
            end
        end)
    end
end)

